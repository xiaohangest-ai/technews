# 本地手动跑时复制成 .env 用，不会被 git 追踪。
# 在 GitHub 上不需要这个文件 —— 用 Repo → Settings → Secrets 来配。

APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：覆盖 Lark API base
# 国际版：https://open.larksuite.com/open-apis （默认）
# 国内飞书：https://open.feishu.cn/open-apis
# LARK_BASE=https://open.larksuite.com/open-apis
